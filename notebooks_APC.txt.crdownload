# The PCA scatter plot provides a two-dimensional representation of the dataset using the first two principal components. The SVM decision boundary divides the feature space into regions corresponding to different classes.
# 
# If the data points from different classes overlap significantly, it indicates that the features do not strongly distinguish between classes. This can result in lower classification accuracy.
# 
# In this case, the presence of overlapping regions suggests that the dataset is complex and may require additional feature engineering or more advanced models. From an industrial perspective, poor class separation can lead to unreliable fault detection, which may affect system safety and maintenance decisions.

# This script implements a complete machine learning pipeline for fault detection, including:
# 
# Data splitting (training/testing)
# Feature scaling (standardisation)
# Training multiple models:
# Support Vector Machine (SVM)
# Random Forest (RF)
# Multilayer Perceptron (MLP)
# Model evaluation using:
# Accuracy
# Confusion Matrix
# Classification Report
# ROC Curve
# 
# 👉 Goal: Compare models and identify the best algorithm for fault detection in chemical systems.

"""
step4_ml_pipeline.py

Full ML pipeline for Fault Detection:
- Train/Test split
- Standardization
- Models: SVM, Random Forest, MLP
- Evaluation: accuracy, confusion matrix, classification report
- Visualizations: confusion matrices, ROC curves
"""

import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
from sklearn.model_selection import train_test_split
from sklearn.preprocessing import StandardScaler, label_binarize
from sklearn.metrics import accuracy_score, confusion_matrix, classification_report, roc_curve, auc
from sklearn.svm import SVC
from sklearn.ensemble import RandomForestClassifier
from sklearn.neural_network import MLPClassifier

# Optional seaborn for nicer plots
try:
    import seaborn as sns
    sns.set(style="whitegrid")
except:
    pass

# -------------------------
# Utility functions
# -------------------------
def plot_confusion_matrix(cm, classes, title='Confusion matrix', cmap=plt.cm.Blues):
    plt.figure(figsize=(6,5))
    plt.imshow(cm, interpolation='nearest', cmap=cmap)
    plt.title(title)
    plt.colorbar()
    tick_marks = np.arange(len(classes))
    plt.xticks(tick_marks, classes, rotation=45)
    plt.yticks(tick_marks, classes)
    fmt = 'd'
    thresh = cm.max() / 2.
    for i, j in np.ndindex(cm.shape):
        plt.text(j, i, format(cm[i, j], fmt),
                 horizontalalignment="center",
                 color="white" if cm[i, j] > thresh else "black")
    plt.ylabel('True label')
    plt.xlabel('Predicted label')
    plt.tight_layout()
    plt.show()


def plot_roc_curves(models, X_test, y_test, n_classes):
    plt.figure(figsize=(8,6))
    for name, clf in models.items():
        if n_classes == 2:
            y_score = clf.decision_function(X_test) if hasattr(clf, "decision_function") else clf.predict_proba(X_test)[:,1]
            fpr, tpr, _ = roc_curve(y_test, y_score)
            roc_auc = auc(fpr, tpr)
            plt.plot(fpr, tpr, label=f'{name} (AUC={roc_auc:.2f})')
        else:
            # multi-class: one-vs-rest
            y_bin = label_binarize(y_test, classes=np.arange(n_classes))
            y_score = clf.predict_proba(X_test)
            for i in range(n_classes):
                fpr, tpr, _ = roc_curve(y_bin[:,i], y_score[:,i])
                roc_auc = auc(fpr, tpr)
                plt.plot(fpr, tpr, label=f'{name}-class{i} (AUC={roc_auc:.2f})')
    plt.plot([0,1],[0,1],'k--')
    plt.xlabel('False Positive Rate')
    plt.ylabel('True Positive Rate')
    plt.title('ROC Curves')
    plt.legend()
    plt.grid(True)
    plt.tight_layout()
    plt.show()


# -------------------------
# Full ML pipeline
# -------------------------
def run_ml_pipeline(df, target_col, test_size=0.2, random_state=42):
    # Split features and target
    X = df.drop(columns=[target_col]).values
    y = df[target_col].values

    # Train/test split
    X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=test_size, random_state=random_state, stratify=y)

    # Standardization
    scaler = StandardScaler()
    X_train = scaler.fit_transform(X_train)
    X_test = scaler.transform(X_test)

    # Define models
    models = {
        "SVM": SVC(kernel='rbf', C=1.0, gamma='scale', probability=True, random_state=random_state),
        "RandomForest": RandomForestClassifier(n_estimators=200, max_depth=None, random_state=random_state),
        "MLP": MLPClassifier(hidden_layer_sizes=(64,32), activation='relu', solver='adam', max_iter=500, random_state=random_state)
    }

    results = {}

    for name, clf in models.items():
        print(f"\n[INFO] Training {name}...")
        clf.fit(X_train, y_train)
        y_pred = clf.predict(X_test)
        acc = accuracy_score(y_test, y_pred)
        cm = confusion_matrix(y_test, y_pred)
        cr = classification_report(y_test, y_pred)
        results[name] = {"model": clf, "accuracy": acc, "confusion_matrix": cm, "classification_report": cr}

        print(f"{name} Accuracy: {acc:.4f}")
        print(f"Classification Report:\n{cr}")
        plot_confusion_matrix(cm, classes=np.unique(y), title=f'{name} Confusion Matrix')

    # ROC Curves
    n_classes = len(np.unique(y))
    plot_roc_curves(models, X_test, y_test, n_classes)

    return results, scaler


# -------------------------
# Example usage
# -------------------------
if __name__ == "__main__":
    # Synthetic dataset
    from sklearn.datasets import make_classification
    X, y = make_classification(n_samples=1000, n_features=20, n_informative=8, n_redundant=2,
                               n_classes=2, random_state=42)
    df_demo = pd.DataFrame(X, columns=[f"x{i+1}" for i in range(X.shape[1])])
    df_demo['target'] = y

    results, scaler = run_ml_pipeline(df_demo, target_col='target')


