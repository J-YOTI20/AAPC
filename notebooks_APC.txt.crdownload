# This module is used to load datasets from various file formats and perform initial preprocessing steps such as missing value analysis, data standardisation, and feature preparation. This ensures that the dataset is clean and suitable for machine learning model development.

"""
data_loader.py

Purpose
-------
Utility functions for robust dataset loading and first-pass inspection for
a Nanoelectronics / Fault Detection ML pipeline.

Features
--------
- Load from CSV, Excel, MAT, NPZ, HDF5, Pickle.
- Auto-detect file type when path provided.
- Basic metadata and missing-value report.
- Optionally:
    - select features and target column
    - drop or impute missing values
    - standardize / normalize numeric columns
    - save a cleaned copy

Returns
-------
A tuple: (pandas.DataFrame, dict(metadata))
"""

import os
import warnings
from typing import Optional, Tuple, Dict, Any, List, Union

import numpy as np
import pandas as pd

# Optional dependencies for some file formats
try:
    import scipy.io as sio  # for .mat
except Exception:
    sio = None
try:
    import h5py  # for hdf5 inspection
except Exception:
    h5py = None


# -------------------------
# Helper loading functions
# -------------------------
def _load_csv(path: str, **kwargs) -> pd.DataFrame:
    return pd.read_csv(path, **kwargs)


def _load_excel(path: str, sheet_name: Union[str, int] = 0, **kwargs) -> pd.DataFrame:
    return pd.read_excel(path, sheet_name=sheet_name, **kwargs)


def _load_mat(path: str, varname: Optional[str] = None) -> pd.DataFrame:
    if sio is None:
        raise ImportError("scipy is required to load MATLAB .mat files. Install scipy.")
    mat = sio.loadmat(path, squeeze_me=True, struct_as_record=False)
    # If user provided a varname, try to extract it
    if varname:
        if varname not in mat:
            raise KeyError(f"Variable '{varname}' not found in {path}. Available keys: {list(mat.keys())}")
        arr = mat[varname]
    else:
        # attempt common keys
        candidates = [k for k in mat.keys() if not k.startswith("__")]
        if len(candidates) == 1:
            arr = mat[candidates[0]]
        else:
            # pick the largest array-like key
            arr = None
            maxsize = 0
            for k in candidates:
                val = mat[k]
                try:
                    s = np.array(val).size
                    if s > maxsize:
                        arr = val
                        maxsize = s
                except Exception:
                    continue
            if arr is None:
                raise RuntimeError("Couldn't auto-select a variable from the .mat file; pass varname argument.")
    # Convert to DataFrame if 2D-like
    arr = np.asarray(arr)
    if arr.ndim == 2:
        return pd.DataFrame(arr)
    elif arr.ndim == 1:
        return pd.DataFrame(arr, columns=[varname or "var"])
    else:
        raise ValueError("Loaded .mat variable has ndim > 2; provide preprocessing outside loader.")


def _load_npz(path: str) -> pd.DataFrame:
    with np.load(path, allow_pickle=True) as d:
        # If single array present, return that; else try to find 'data' or first large array
        keys = list(d.keys())
        if len(keys) == 1:
            arr = d[keys[0]]
            arr = np.asarray(arr)
            if arr.ndim == 2:
                return pd.DataFrame(arr)
            elif arr.ndim == 1:
                return pd.DataFrame(arr, columns=[keys[0]])
        # multiple arrays: create DataFrame if shapes align across first dimension
        shapes = [np.shape(d[k]) for k in keys]
        first_dim = [s[0] if len(s) > 0 else None for s in shapes]
        if all(fd == first_dim[0] for fd in first_dim):
            df = pd.DataFrame({k: d[k] for k in keys})
            return df
        else:
            # fallback: return dictionary-like DataFrame with object dtype
            return pd.DataFrame({k: d[k] for k in keys})


def _load_pickle(path: str) -> pd.DataFrame:
    obj = pd.read_pickle(path)
    if isinstance(obj, pd.DataFrame):
        return obj
    else:
        # try to convert to DataFrame
        try:
            return pd.DataFrame(obj)
        except Exception as e:
            raise ValueError(f"Pickle loaded object of type {type(obj)} cannot be converted to DataFrame: {e}")


def _load_hdf5(path: str, key: Optional[str] = None) -> pd.DataFrame:
    if key is not None:
        return pd.read_hdf(path, key)
    else:
        # try to guess the key
        with pd.HDFStore(path, mode='r') as store:
            keys = store.keys()
            if len(keys) == 0:
                raise KeyError("No datasets found in HDF5 file.")
            # choose first key
            chosen = keys[0].lstrip('/')
            return pd.read_hdf(path, chosen)


# -------------------------
# Main loader
# -------------------------
def load_dataset(
    path: Optional[str] = None,
    *,
    file_type: Optional[str] = None,
    sheet_name: Union[str, int] = 0,
    mat_varname: Optional[str] = None,
    hdf_key: Optional[str] = None,
    index_col: Optional[Union[int, str]] = None,
    dtype: Optional[dict] = None,
    parse_dates: Optional[List[str]] = None,
    verbose: bool = True
) -> Tuple[pd.DataFrame, Dict[str, Any]]:
    """
    Load a dataset from `path` and return (df, metadata).

    Parameters
    ----------
    path : str or None
        Path to the dataset file. If None, a synthetic dataset is returned.
    file_type : str or None
        One of: 'csv', 'excel', 'mat', 'npz', 'hdf5', 'pickle'. If None, auto-detected from extension.
    sheet_name : for excel
    mat_varname : optional variable name when loading .mat
    hdf_key : key when loading hdf5
    index_col : column to use as index
    dtype : dict, optional dtypes to pass to pandas.read_csv/read_excel
    parse_dates : list of columns to parse as dates
    verbose : bool
        print metadata and missing-value report if True.

    Returns
    -------
    df : pandas.DataFrame
    metadata : dict
        includes source, shape, dtypes, missing_counts, column_names
    """
    if path is None:
        # generate a synthetic dataset for quick testing
        from sklearn.datasets import make_classification
        X, y = make_classification(n_samples=1000, n_features=20, n_informative=6, n_redundant=2,
                                   n_classes=2, random_state=42)
        cols = [f"x{i+1}" for i in range(X.shape[1])]
        df = pd.DataFrame(X, columns=cols)
        df['target'] = y
        metadata = {
            "source": "synthetic:sklearn.make_classification",
            "shape": df.shape,
            "columns": df.columns.tolist()
        }
        if verbose:
            print(f"[INFO] Generated synthetic dataset: shape={df.shape}")
        return df, metadata

    if not os.path.exists(path):
        raise FileNotFoundError(f"File not found: {path}")

    ext = os.path.splitext(path)[1].lower()
    if file_type is None:
        if ext in ['.csv']:
            file_type = 'csv'
        elif ext in ['.xls', '.xlsx']:
            file_type = 'excel'
        elif ext in ['.mat']:
            file_type = 'mat'
        elif ext in ['.npz', '.npy']:
            file_type = 'npz'
        elif ext in ['.h5', '.hdf5', '.hdf']:
            file_type = 'hdf5'
        elif ext in ['.pkl', '.pickle']:
            file_type = 'pickle'
        else:
            # fallback: try pandas read_csv and then read_excel
            warnings.warn(f"Unknown extension '{ext}', attempting csv -> excel -> pickle -> npz -> mat.")
            tried = False
            try:
                df = pd.read_csv(path)
                file_type = 'csv'
                tried = True
            except Exception:
                try:
                    df = pd.read_excel(path)
                    file_type = 'excel'
                    tried = True
                except Exception:
                    pass
            if tried:
                # continue to standard flow below with df already loaded
                metadata = {
                    "source": path,
                    "inferred_file_type": file_type,
                    "shape": df.shape,
                    "columns": df.columns.tolist()
                }
                # Add missing value report
                missing = df.isna().sum().to_dict()
                metadata['missing_counts'] = missing
                if verbose:
                    print("[INFO] Auto-detected and loaded (fallback).")
                    print(metadata)
                return df, metadata
            else:
                raise ValueError(f"Could not determine file type for {path}. Please specify file_type explicitly.")

    # Now load according to file_type
    if file_type == 'csv':
        df = _load_csv(path, index_col=index_col, dtype=dtype, parse_dates=parse_dates)
    elif file_type == 'excel':
        df = _load_excel(path, sheet_name=sheet_name, index_col=index_col, dtype=dtype)
    elif file_type == 'mat':
        df = _load_mat(path, varname=mat_varname)
    elif file_type in ('npz', 'npy'):
        df = _load_npz(path)
    elif file_type == 'pickle':
        df = _load_pickle(path)
    elif file_type == 'hdf5':
        df = _load_hdf5(path, key=hdf_key)
    else:
        raise ValueError(f"Unsupported file_type: {file_type}")

    # metadata and quick checks
    metadata = {
        "source": path,
        "file_type": file_type,
        "shape": df.shape,
        "columns": df.columns.tolist(),
        "dtypes": df.dtypes.apply(lambda x: str(x)).to_dict(),
    }

    # missing values
    missing_counts = df.isna().sum()
    metadata['missing_counts'] = missing_counts.to_dict()
    metadata['missing_fraction'] = (missing_counts / len(df)).to_dict()

    # numeric / categorical split
    numeric_cols = df.select_dtypes(include=[np.number]).columns.tolist()
    categorical_cols = df.select_dtypes(exclude=[np.number]).columns.tolist()
    metadata['numeric_columns'] = numeric_cols
    metadata['categorical_columns'] = categorical_cols

    if verbose:
        print(f"[INFO] Loaded dataset from {path}")
        print(f"       file_type: {file_type}")
        print(f"       shape    : {df.shape}")
        print(f"       numeric cols  : {len(numeric_cols)}")
        print(f"       categorical cols: {len(categorical_cols)}")
        n_missing = missing_counts.sum()
        print(f"       missing values : {n_missing} ({n_missing/ (df.shape[0]*df.shape[1]):.2%} of cells)")
        # show top 10 missing columns if any
        ms_sorted = missing_counts[missing_counts > 0].sort_values(ascending=False)
        if len(ms_sorted) > 0:
            print("       top missing columns:")
            print(ms_sorted.head(10).to_string())

    return df, metadata


# -------------------------
# Simple cleaning helpers
# -------------------------
def basic_impute(df: pd.DataFrame, strategy: str = 'mean', fill_value: Optional[Any] = None,
                 numeric_only: bool = True) -> pd.DataFrame:
    """
    Basic imputation helper: 'mean', 'median', 'mode', or 'constant' (fill_value required).
    """
    df = df.copy()
    if strategy not in ('mean', 'median', 'mode', 'constant'):
        raise ValueError("strategy must be one of 'mean','median','mode','constant'")

    if numeric_only:
        numeric_cols = df.select_dtypes(include=[np.number]).columns
    else:
        numeric_cols = df.columns

    if strategy == 'mean':
        for c in numeric_cols:
            if df[c].isna().any():
                df[c].fillna(df[c].mean(), inplace=True)
    elif strategy == 'median':
        for c in numeric_cols:
            if df[c].isna().any():
                df[c].fillna(df[c].median(), inplace=True)
    elif strategy == 'mode':
        for c in numeric_cols:
            if df[c].isna().any():
                df[c].fillna(df[c].mode().iloc[0] if not df[c].mode().empty else df[c].dropna().iloc[0], inplace=True)
    elif strategy == 'constant':
        if fill_value is None:
            raise ValueError("fill_value must be provided for constant strategy")
        for c in numeric_cols:
            df[c].fillna(fill_value, inplace=True)

    return df


def drop_high_missing(df: pd.DataFrame, threshold: float = 0.5) -> pd.DataFrame:
    """
    Drop columns with fraction of missing values > threshold.
    threshold: fraction in (0,1)
    """
    df = df.copy()
    frac = df.isna().mean()
    dropcols = frac[frac > threshold].index.tolist()
    if len(dropcols) > 0:
        df.drop(columns=dropcols, inplace=True)
    return df


def standardize_numeric(df: pd.DataFrame, numeric_cols: Optional[List[str]] = None) -> Tuple[pd.DataFrame, Dict[str, Any]]:
    """
    Standardize numeric columns to zero mean and unit variance (z-score).
    Returns (df_standardized, stats_dict) where stats_dict contains mean and std per column.
    """
    df = df.copy()
    if numeric_cols is None:
        numeric_cols = df.select_dtypes(include=[np.number]).columns.tolist()
    stats = {}
    for c in numeric_cols:
        mu = df[c].mean()
        sigma = df[c].std(ddof=0)  # population std
        if sigma == 0 or np.isnan(sigma):
            df[c] = 0.0
            stats[c] = {"mean": float(mu), "std": float(sigma)}
        else:
            df[c] = (df[c] - mu) / sigma
            stats[c] = {"mean": float(mu), "std": float(sigma)}
    return df, stats


# -------------------------
# Example usage (not run on import)
# -------------------------
if __name__ == "__main__":
    # Example 1: generate synthetic data
    df_synth, meta_synth = load_dataset(None, verbose=True)
    print(meta_synth)

    # Example 2: load a CSV file
    # df, meta = load_dataset("fault_free_training.csv", file_type="csv", verbose=True)

    # Example 3: load a MATLAB file
    # df_mat, meta_mat = load_dataset("tep_data.mat", file_type="mat", mat_varname="X")

    # Quick cleaning example
    df_cleaned = basic_impute(df_synth, strategy='mean')
    df_cleaned = drop_high_missing(df_cleaned, threshold=0.5)
    df_standardized, stats = standardize_numeric(df_cleaned)
    print("Standardization stats (first 5):", dict(list(stats.items())[:5]))


