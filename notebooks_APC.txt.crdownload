# -------------------------
# 1. Imports
# -------------------------
import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
from sklearn.decomposition import PCA
from sklearn.preprocessing import StandardScaler, label_binarize
from sklearn.model_selection import train_test_split
from sklearn.svm import SVC
from sklearn.ensemble import RandomForestClassifier
from sklearn.neural_network import MLPClassifier
from sklearn.metrics import accuracy_score, confusion_matrix, classification_report, roc_curve, auc

# Optional: seaborn for nicer visuals
try:
    import seaborn as sns
    sns.set(style='whitegrid')
except:
    pass

# -------------------------
# 2. Dataset Loading
# -------------------------
# Replace 'fault_free_training.csv' with your dataset path
try:
    df = pd.read_csv('fault_free_training.csv')
    print('Dataset loaded successfully.')
except FileNotFoundError:
    print('CSV file not found. Using synthetic demo dataset.')
    from sklearn.datasets import make_classification
    X, y = make_classification(n_samples=500, n_features=10, n_informative=5, n_redundant=2, n_classes=2, random_state=42)
    df = pd.DataFrame(X, columns=[f'x{i+1}' for i in range(X.shape[1])])
    df['target'] = y

print(df.head())

# -------------------------
# 3. Exploratory Data Analysis (EDA)
# -------------------------
# 3.1 Correlation Matrix
numeric_cols = df.select_dtypes(include=[np.number]).columns.tolist()
numeric_cols.remove('target') if 'target' in numeric_cols else None

plt.figure(figsize=(10,8))
if 'sns' in globals():
    sns.heatmap(df[numeric_cols].corr(), annot=False, cmap='coolwarm', square=True)
    plt.title('Correlation Matrix')
else:
    plt.matshow(df[numeric_cols].corr(), cmap='coolwarm')
plt.show()

# 3.2 Distribution Plots
plt.figure(figsize=(12,8))
n_cols = 3
for i, c in enumerate(numeric_cols, 1):
    plt.subplot(int(np.ceil(len(numeric_cols)/n_cols)), n_cols, i)
    plt.hist(df[c].dropna(), bins=50, alpha=0.7)
    plt.title(c)
plt.tight_layout()
plt.show()

# 3.3 Missingness Heatmap
plt.figure(figsize=(12,6))
if 'sns' in globals():
    sns.heatmap(df.isna(), cbar=False, cmap='Greys', linewidths=0.2)
    plt.title('Missingness Heatmap')
else:
    plt.imshow(df.isna().values, aspect='auto', cmap='gray_r')
plt.show()

# 3.4 PCA Explained Variance Plot
X = df[numeric_cols].values
scaler = StandardScaler()
X_scaled = scaler.fit_transform(X)
pca = PCA(n_components=min(X_scaled.shape[1], X_scaled.shape[0]))
pca.fit(X_scaled)
explained_cum = np.cumsum(pca.explained_variance_ratio_)
plt.figure(figsize=(8,5))
plt.plot(range(1,len(explained_cum)+1), explained_cum, marker='o')
plt.xlabel('Principal Component')
plt.ylabel('Cumulative Explained Variance')
plt.title('PCA Explained Variance')
plt.grid(True)
plt.show()

# -------------------------
# 4. PCA Scatter with SVM Decision Boundary
# -------------------------
X_pca = PCA(n_components=2).fit_transform(X_scaled)
y = df['target'].values

clf_svm = SVC(kernel='rbf', C=1.0, gamma='scale', probability=True)
clf_svm.fit(X_pca, y)

# Meshgrid for boundary
x_min, x_max = X_pca[:,0].min()-1, X_pca[:,0].max()+1
y_min, y_max = X_pca[:,1].min()-1, X_pca[:,1].max()+1
xx, yy = np.meshgrid(np.linspace(x_min,x_max,500), np.linspace(y_min,y_max,500))
Z = clf_svm.predict(np.c_[xx.ravel(), yy.ravel()]).reshape(xx.shape)

plt.figure(figsize=(8,6))
plt.contourf(xx, yy, Z, alpha=0.2, cmap=plt.cm.coolwarm)
plt.scatter(X_pca[:,0], X_pca[:,1], c=y, cmap=plt.cm.coolwarm, edgecolor='k', s=50)
plt.xlabel('PC1')
plt.ylabel('PC2')
plt.title('PCA Scatter with SVM Decision Boundary')
plt.show()

# -------------------------
# 5. Full ML Pipeline (SVM, Random Forest, MLP)
# -------------------------
X_train, X_test, y_train, y_test = train_test_split(X_scaled, y, test_size=0.2, random_state=42, stratify=y)

models = {
    'SVM': SVC(kernel='rbf', C=1.0, gamma='scale', probability=True, random_state=42),
    'RandomForest': RandomForestClassifier(n_estimators=200, random_state=42),
    'MLP': MLPClassifier(hidden_layer_sizes=(64,32), max_iter=500, random_state=42)
}

for name, clf in models.items():
    clf.fit(X_train, y_train)
    y_pred = clf.predict(X_test)
    acc = accuracy_score(y_test, y_pred)
    cm = confusion_matrix(y_test, y_pred)
    print(f'[{name}] Accuracy: {acc:.4f}')
    print(classification_report(y_test, y_pred))
    # Plot confusion matrix
    plt.figure(figsize=(5,4))
    if 'sns' in globals():
        sns.heatmap(cm, annot=True, fmt='d', cmap='Blues')
    else:
        plt.imshow(cm, cmap='Blues')
    plt.title(f'{name} Confusion Matrix')
    plt.xlabel('Predicted')
    plt.ylabel('True')
    plt.show()

# ROC Curves
plt.figure(figsize=(8,6))
n_classes = len(np.unique(y))
for name, clf in models.items():
    if n_classes == 2:
        y_score = clf.decision_function(X_test) if hasattr(clf, 'decision_function') else clf.predict_proba(X_test)[:,1]
        fpr, tpr, _ = roc_curve(y_test, y_score)
        roc_auc = auc(fpr, tpr)
        plt.plot(fpr, tpr, label=f'{name} (AUC={roc_auc:.2f})')
    else:
        y_bin = label_binarize(y_test, classes=np.arange(n_classes))
        y_score = clf.predict_proba(X_test)
        for i in range(n_classes):
            fpr, tpr, _ = roc_curve(y_bin[:,i], y_score[:,i])
            roc_auc = auc(fpr, tpr)
            plt.plot(fpr, tpr, label=f'{name}-class{i} (AUC={roc_auc:.2f})')
plt.plot([0,1],[0,1],'k--')
plt.xlabel('False Positive Rate')
plt.ylabel('True Positive Rate')
plt.title('ROC Curves')
plt.legend()
plt.grid(True)
plt.show()


