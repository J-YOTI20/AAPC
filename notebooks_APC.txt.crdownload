# The PCA-SVM visualisation provides insight into the separability of the dataset. If the classes overlap significantly in the PCA space, it indicates that the original features do not strongly differentiate between fault conditions.
# 
# In this case, the SVM decision boundary attempts to separate the classes, but overlapping regions suggest that classification accuracy may be limited. This highlights the complexity of the dataset and the need for additional feature engineering or more advanced models.
# 
# From an industrial perspective, poor separation between fault and normal conditions can lead to unreliable predictions, which may affect maintenance decisions and system safety.

"""
Step 3: PCA Scatter Plot with SVM Decision Boundary
"""

import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
from sklearn.decomposition import PCA
from sklearn.svm import SVC
from sklearn.preprocessing import StandardScaler
from sklearn.model_selection import train_test_split
from matplotlib.colors import ListedColormap

def pca_svm_scatter(
    df: pd.DataFrame,
    numeric_cols: list,
    target_col: str,
    test_size: float = 0.2,
    random_state: int = 42,
    kernel: str = 'rbf',
    C: float = 1.0,
    gamma: str = 'scale',
    figsize: tuple = (8, 6),
    savepath: str = None
):
    """
    Perform PCA (2 components), train an SVM classifier, and plot the scatter
    of the first 2 PCs with SVM decision boundary.

    Parameters
    ----------
    df : DataFrame
        Input dataset
    numeric_cols : list
        Numeric feature columns
    target_col : str
        Label column
    """
    # 1. Prepare data
    X = df[numeric_cols].values
    y = df[target_col].values

    # Standardize features
    scaler = StandardScaler()
    X_scaled = scaler.fit_transform(X)

    # PCA reduction to 2 components
    pca = PCA(n_components=2)
    X_pca = pca.fit_transform(X_scaled)

    # Train/test split
    X_train, X_test, y_train, y_test = train_test_split(X_pca, y, test_size=test_size, random_state=random_state, stratify=y)

    # SVM classifier
    svm = SVC(kernel=kernel, C=C, gamma=gamma, probability=True, random_state=random_state)
    svm.fit(X_train, y_train)

    # Prepare meshgrid for decision boundary
    x_min, x_max = X_pca[:, 0].min() - 1, X_pca[:, 0].max() + 1
    y_min, y_max = X_pca[:, 1].min() - 1, X_pca[:, 1].max() + 1
    xx, yy = np.meshgrid(np.arange(x_min, x_max, 0.02),
                         np.arange(y_min, y_max, 0.02))
    Z = svm.predict(np.c_[xx.ravel(), yy.ravel()])
    Z = Z.reshape(xx.shape)

    # Plot
    plt.figure(figsize=figsize)
    cmap_light = ListedColormap(['#FFAAAA', '#AAAAFF', '#AAFFAA'])
    cmap_bold = ListedColormap(['#FF0000', '#0000FF', '#00AA00'])
    plt.contourf(xx, yy, Z, alpha=0.2, cmap=cmap_light)

    # Scatter points
    for label in np.unique(y):
        idx = np.where(y == label)
        plt.scatter(X_pca[idx, 0], X_pca[idx, 1], label=f"Class {label}", cmap=cmap_bold, edgecolor='k', s=50)

    plt.xlabel("PC1")
    plt.ylabel("PC2")
    plt.title("PCA Scatter Plot with SVM Decision Boundary")
    plt.legend()
    plt.grid(alpha=0.3)
    plt.tight_layout()

    if savepath:
        plt.savefig(savepath, dpi=200)
    plt.show()

    # Return objects for further analysis
    return X_pca, y, svm, pca, scaler


# -------------------------
# Example usage
# -------------------------
if __name__ == "__main__":
    from sklearn.datasets import make_classification
    # Synthetic dataset
    X, y = make_classification(n_samples=500, n_features=10, n_informative=6, n_redundant=2,
                               n_classes=2, random_state=42)
    cols = [f"x{i+1}" for i in range(X.shape[1])]
    df = pd.DataFrame(X, columns=cols)
    df['target'] = y

    X_pca, y_vals, svm_model, pca_model, scaler = pca_svm_scatter(df, numeric_cols=cols, target_col='target')


